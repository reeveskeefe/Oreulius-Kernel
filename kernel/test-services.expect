#!/usr/bin/expect -f
# Test script for service functionality using expect

set timeout 30

cd [file dirname [info script]]

if {![file exists "oreulius.iso"]} {
    puts "oreulius.iso not found; run ./build.sh first"
    exit 1
}

# Start QEMU
spawn ./run.sh

# Wait for shell prompt
expect "> "

# Test service commands
send "svc-list\r"
expect "> "

send "svc-register filesystem\r"
expect "> "

send "svc-register console\r"
expect "> "

send "svc-register timer\r"
expect "> "

send "svc-list\r"
expect "> "

send "svc-stats\r"
expect "> "

send "svc-request filesystem\r"
expect "> "

send "svc-request console\r"
expect "> "

send "svc-request timer\r"
expect "> "

# Wait a bit and exit
sleep 2
send "\x03"  # Send Ctrl+C to exit
